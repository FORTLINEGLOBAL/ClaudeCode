# Fortline Outbound Agents — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# ---- Anthropic (Fortline-dedicated project) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Fortline State MCP ----
FORTLINE_DB_URL=postgres://fortline_user:PASSWORD@localhost:5432/fortline_db
FORTLINE_STATE_MCP_URL=https://your-mcp-server.example.com/mcp
FORTLINE_STATE_MCP_TOKEN=your-mcp-token

# ---- forti-email backend ----
FORTI_EMAIL_USER=eddie@fortlineglobal.com
FORTI_EMAIL_PASSWORD=your-imap-smtp-password
FORTI_SMTP_HOST=mail.fortlineglobal.com
FORTI_SMTP_PORT=587
FORTI_IMAP_HOST=mail.fortlineglobal.com
FORTI_IMAP_PORT=993
FORTI_EMAIL_API_KEY=generate-a-strong-random-key
FORTI_EMAIL_BACKEND_URL=https://your-email-backend.example.com

# ---- Clay (LinkedIn enrichment) ----
CLAY_API_KEY=your-clay-api-key

# ---- Slack ----
SLACK_MCP_TOKEN=xoxb-...

# ---- Dashboard (frontend reads these at runtime) ----
# Set via window.FORTLINE_STATE_URL and window.FORTI_EMAIL_URL in the HTML,
# or inject via your hosting platform (Vercel env vars, etc.)
